#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_install:
	mkdir -p debian/tibackup/usr/bin
	mkdir -p debian/tibackup/etc/tibackup
	mkdir -p debian/tibackup/var/lib/tibackup/www
	cp -a obj-x86_64-linux-gnu/tiBackup debian/tibackup/usr/bin/.
	cp -a var/www/* debian/tibackup/var/lib/tibackup/www/.
	# Self-signed web-cert generator, shared by the postinst and
	# `tiBackup --regenerate-web-cert`.
	install -D -m 0755 scripts/gen-web-cert.sh debian/tibackup/usr/lib/tibackup/gen-web-cert
	# Commented sudoers template for the unprivileged script-runner user (0440,
	# root-owned as sudoers requires). Ships with no active rules.
	install -D -m 0440 etc/sudoers.d/tibackup-scripts debian/tibackup/etc/sudoers.d/tibackup-scripts
	# logrotate for the held-open tibackup.log (copytruncate) and tmpfiles age-
	# cleanup for the write-once run/rsync logs (see the files for rationale).
	# Logs live under /var/log/tibackup; the dir is created by the postinst.
	install -D -m 0644 etc/logrotate.d/tibackup debian/tibackup/etc/logrotate.d/tibackup
	install -D -m 0644 etc/tmpfiles.d/tibackup.conf debian/tibackup/usr/lib/tmpfiles.d/tibackup.conf

# The tibackupd systemd unit ships as debian/tibackup.tibackupd.service. Because
# the unit name (tibackupd) differs from the package name (tibackup), dh_installsystemd
# needs --name to pick it up, install it to /usr/lib/systemd/system and enable/start it.
override_dh_installsystemd:
	dh_installsystemd --name=tibackupd

override_dh_builddeb:
	dh_builddeb -- -Zxz
